# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=AI Inventory Management System
VERSION=1.0.0
DESCRIPTION=Production-ready inventory management system with AI forecasting

# CORS Settings (comma-separated origins)
BACKEND_CORS_ORIGINS=["http://localhost","http://127.0.0.1","http://localhost:3000","http://localhost:5173","http://localhost:5174","http://127.0.0.1:3000","http://127.0.0.1:5173","http://127.0.0.1:5174"]

# Security Settings
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_DB=ai_inventory_db
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
# Or use DATABASE_URI directly:
# DATABASE_URI=postgresql+asyncpg://user:password@localhost:5432/inventory_db

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Email Settings (optional)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@inventory.com
EMAILS_FROM_NAME=Inventory System

# Super Admin
FIRST_SUPERUSER_EMAIL=admin@inventory.com
FIRST_SUPERUSER_PASSWORD=admin123

# Environment
ENVIRONMENT=development
DEBUG=True

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# File Upload
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=uploads

# AI/ML Settings
AI_MODEL_PATH=models/
FORECAST_DAYS=30

# ============================================================================
# Azure OpenAI — LLM provider for MARA Planning Copilot
# All four variables must be set before using the /planning/copilot endpoint.
# All other planning API endpoints work without LLM credentials.
#
# To find these values:
#   Azure Portal → your OpenAI resource → Keys and Endpoint
#   Azure Portal → your OpenAI resource → Model deployments (for DEPLOYMENT name)
# ============================================================================
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ============================================================================
# MCP Planning Server
# The MARA MCP server runs as a background service on this host and port.
# Agents communicate with the MCP server through the MCPPlanningClient.
# ============================================================================
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8001
MCP_SERVER_TIMEOUT=30.0
